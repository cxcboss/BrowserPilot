{
  "manifest_version": 3,
  "name": "BrowserPilot 浏览器助手",
  "version": "0.1.0",
  "description": "通过 MCP 实现 AI 驱动的浏览器控制。让 AI 助手读取、导航和操作你的浏览器。",
  "permissions": [
    "debugger",
    "tabs",
    "activeTab",
    "cookies",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html"
  }
}
